# Copy to .env.local and fill in for production email delivery.
# Without these, form submissions still succeed; the server logs the payload and skips email.

# Get a key at https://resend.com — free tier is enough for MVP testing.
RESEND_API_KEY=

# Verified sender, e.g. "EC Totes <onboarding@resend.dev>" for Resend sandbox, or your domain after DNS setup.
RESEND_FROM=

# Comma-separated inbox(es) that receive reservation notifications.
RESEND_TO=you@example.com
